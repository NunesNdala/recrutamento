<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/isph/recrutamento#"
     xml:base="http://www.semanticweb.org/isph/recrutamento"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rec="http://www.semanticweb.org/isph/recrutamento#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/isph/recrutamento">
        <rdfs:comment xml:lang="pt">
            Ontologia que modela o domínio de recrutamento e selecção de recursos humanos,
            representando candidatos, vagas, empresas, competências, formações,
            candidaturas e entrevistas, bem como as relações semânticas entre elas.
        </rdfs:comment>
        <rdfs:label xml:lang="pt">Ontologia de Recrutamento</rdfs:label>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/isph/recrutamento#dataHistorico -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#dataHistorico"/>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#etapaHistorico -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#etapaHistorico"/>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#etapaSeleção -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#etapaSeleção"/>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#notaHistorico -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#notaHistorico"/>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#temHistorico -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#temHistorico"/>
    


    <!-- http://xmlns.com/foaf/0.1/mbox -->

    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/mbox"/>
    


    <!-- http://xmlns.com/foaf/0.1/name -->

    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/name"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/isph/recrutamento#conduzEntrevista -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#conduzEntrevista">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Recrutador"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#Entrevista"/>
        <rdfs:label xml:lang="pt">conduz entrevista</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#exige -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#exige">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Empresa"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#Competencia"/>
        <rdfs:comment xml:lang="pt">Competências valorizadas genericamente pela empresa.</rdfs:comment>
        <rdfs:label xml:lang="pt">exige</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#geraEntrevista -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#geraEntrevista">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Candidatura"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#Entrevista"/>
        <rdfs:comment xml:lang="pt">Candidatura seleccionada que origina uma entrevista.</rdfs:comment>
        <rdfs:label xml:lang="pt">gera entrevista</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#gereCandidatura -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#gereCandidatura">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Recrutador"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#Candidatura"/>
        <rdfs:label xml:lang="pt">gere candidatura</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#isPublicadaPor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#isPublicadaPor">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/isph/recrutamento#publica"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Vaga"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#Empresa"/>
        <rdfs:label xml:lang="pt">é publicada por</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#isSubmetidaPor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#isSubmetidaPor">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/isph/recrutamento#submeteCandidatura"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Candidatura"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#Candidato"/>
        <rdfs:label xml:lang="pt">é submetida por</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#possuiCompetencia -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#possuiCompetencia">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Candidato"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#Competencia"/>
        <rdfs:comment xml:lang="pt">Competências que o candidato demonstra ter.</rdfs:comment>
        <rdfs:label xml:lang="pt">possui competência</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#possuiExperiencia -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#possuiExperiencia">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Candidato"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#ExperienciaProfissional"/>
        <rdfs:comment xml:lang="pt">Hist?rico profissional associado a um candidato.</rdfs:comment>
        <rdfs:label xml:lang="pt">possui experiencia</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#possuiFormacao -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#possuiFormacao">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Candidato"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#Formacao"/>
        <rdfs:comment xml:lang="pt">Habilitações académicas ou profissionais do candidato.</rdfs:comment>
        <rdfs:label xml:lang="pt">possui formação</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#publica -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#publica">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Empresa"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#Vaga"/>
        <rdfs:comment xml:lang="pt">Relaciona uma empresa com as vagas que ela disponibiliza.</rdfs:comment>
        <rdfs:label xml:lang="pt">publica</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#refereVaga -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#refereVaga">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Candidatura"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#Vaga"/>
        <rdfs:comment xml:lang="pt">Vaga à qual a candidatura se refere.</rdfs:comment>
        <rdfs:label xml:lang="pt">refere vaga</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#requerCompetencia -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#requerCompetencia">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Vaga"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#Competencia"/>
        <rdfs:comment xml:lang="pt">Competências obrigatórias ou desejáveis para uma vaga.</rdfs:comment>
        <rdfs:label xml:lang="pt">requer competência</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#requerExperienciaMinima -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#requerExperienciaMinima">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Vaga"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#ExperienciaProfissional"/>
        <rdfs:comment xml:lang="pt">Experiencia profissional m?nima esperada para uma vaga.</rdfs:comment>
        <rdfs:label xml:lang="pt">requer experiencia minima</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#requerFormacao -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#requerFormacao">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Vaga"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#Formacao"/>
        <rdfs:comment xml:lang="pt">Formação mínima exigida para a vaga.</rdfs:comment>
        <rdfs:label xml:lang="pt">requer formação</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#submeteCandidatura -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#submeteCandidatura">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Candidato"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#Candidatura"/>
        <rdfs:comment xml:lang="pt">Acção do candidato de submeter uma candidatura a uma vaga.</rdfs:comment>
        <rdfs:label xml:lang="pt">submete candidatura</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#trabalhaEm -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#trabalhaEm">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Recrutador"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/isph/recrutamento#Empresa"/>
        <rdfs:comment>Local de trabalho (Empresa)</rdfs:comment>
        <rdfs:label>trabalhaEm</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/isph/recrutamento#anoConclusao -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#anoConclusao">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Formacao"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="pt">ano de conclusão</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#anoExperiencia -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#anoExperiencia">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Candidato"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="pt">anos de experiência</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#anosExperiencia -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#anosExperiencia">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#ExperienciaProfissional"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="pt">anos de experi?ncia</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#areaFormacao -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#areaFormacao">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Formacao"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">área de formação</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#cargoExperiencia -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#cargoExperiencia">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#ExperienciaProfissional"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">cargo</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#categoriaCompetencia -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#categoriaCompetencia">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Competencia"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">categoria</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#dataCandidatura -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#dataCandidatura">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Candidatura"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="pt">data de submissão</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#dataEntrevista -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#dataEntrevista">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Entrevista"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="pt">data e hora</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#dataFimExperiencia -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#dataFimExperiencia">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#ExperienciaProfissional"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="pt">data de fim</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#dataInicioExperiencia -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#dataInicioExperiencia">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#ExperienciaProfissional"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="pt">data de inicio</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#dataPublicacao -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#dataPublicacao">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Vaga"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="pt">data de publicação</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#descricaoVaga -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#descricaoVaga">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Vaga"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">descrição</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#email -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#email">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#empresaExperiencia -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#empresaExperiencia">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#ExperienciaProfissional"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">empresa da experi?ncia</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#estadoCandidatura -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#estadoCandidatura">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Candidatura"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="pt">Valores: Em análise, Aprovada, Rejeitada, Em entrevista, Contratado</rdfs:comment>
        <rdfs:label xml:lang="pt">estado</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#grauFormacao -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#grauFormacao">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Formacao"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="pt">Ex: Licenciatura, Mestrado, Doutoramento, Certificação</rdfs:comment>
        <rdfs:label xml:lang="pt">grau</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#instituicao -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#instituicao">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Formacao"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">instituição</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#localVaga -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#localVaga">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Vaga"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">local de trabalho</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#localizacaoEmpresa -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#localizacaoEmpresa">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Empresa"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">localização</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#modalidade -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#modalidade">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Vaga"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">modalidade (presencial/remoto/híbrido)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#nivelCompetencia -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#nivelCompetencia">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Competencia"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="pt">Valores: Básico, Intermédio, Avançado, Especialista</rdfs:comment>
        <rdfs:label xml:lang="pt">nível</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#nomeCompetencia -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#nomeCompetencia">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Competencia"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">nome da competência</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#nomeCompleto -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#nomeCompleto">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">nome completo</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#nomeEmpresa -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#nomeEmpresa">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Empresa"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">nome da empresa</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#pontuacaoMatch -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#pontuacaoMatch">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Candidatura"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="pt">Pontuação de compatibilidade semântica entre candidato e vaga (0.0 a 1.0).</rdfs:comment>
        <rdfs:label xml:lang="pt">pontuação de compatibilidade</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#referenciaESCO -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#referenciaESCO">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Competencia"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="pt">URI real da taxonomia ESCO associado ? compet?ncia.</rdfs:comment>
        <rdfs:label xml:lang="pt">refer?ncia ESCO</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#resultadoEntrevista -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#resultadoEntrevista">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Entrevista"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="pt">Valores: Aprovado, Reprovado, Pendente</rdfs:comment>
        <rdfs:label xml:lang="pt">resultado</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#salario -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#salario">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Vaga"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="pt">salário (AOA)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#sector -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#sector">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Empresa"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">sector de actividade</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#telefone -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#telefone">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">telefone</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#tipoEntrevista -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#tipoEntrevista">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Entrevista"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="pt">Valores: Técnica, Comportamental, RH, Painel</rdfs:comment>
        <rdfs:label xml:lang="pt">tipo</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#tituloVaga -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/isph/recrutamento#tituloVaga">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/isph/recrutamento#Vaga"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="pt">título da vaga</rdfs:label>
