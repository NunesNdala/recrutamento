    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/isph/recrutamento#Candidato -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#Candidato">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/isph/recrutamento#possuiFormacao"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/isph/recrutamento#Formacao"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/isph/recrutamento#Recrutador"/>
        <rdfs:comment xml:lang="pt">
            Pessoa que se candidata a uma ou mais vagas de emprego.
            Possui competências, formações académicas e pode submeter candidaturas.
        </rdfs:comment>
        <rdfs:label xml:lang="pt">Candidato</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#Candidatura -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#Candidatura">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/isph/recrutamento#refereVaga"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/isph/recrutamento#Vaga"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="pt">
            Acção de um candidato de se candidatar a uma vaga específica,
            com estado e pontuação associados ao processo de selecção.
        </rdfs:comment>
        <rdfs:label xml:lang="pt">Candidatura</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#Competencia -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#Competencia">
        <rdfs:comment xml:lang="pt">
            Habilidade técnica ou comportamental que um candidato pode possuir
            e que uma vaga pode requerer.
        </rdfs:comment>
        <rdfs:label xml:lang="pt">Competência</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#CompetenciaComportamental -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#CompetenciaComportamental">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/isph/recrutamento#Competencia"/>
        <rdfs:comment xml:lang="pt">
            Competência de natureza interpessoal ou comportamental (ex: liderança, comunicação).
        </rdfs:comment>
        <rdfs:label xml:lang="pt">Competência Comportamental</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#CompetenciaTecnica -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#CompetenciaTecnica">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/isph/recrutamento#Competencia"/>
        <rdfs:comment xml:lang="pt">
            Competência de natureza técnica ou tecnológica (ex: programação, gestão de bases de dados).
        </rdfs:comment>
        <rdfs:label xml:lang="pt">Competência Técnica</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#Empresa -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#Empresa">
        <rdfs:comment xml:lang="pt">
            Organização que publica vagas de emprego e conduz processos de recrutamento.
        </rdfs:comment>
        <rdfs:label xml:lang="pt">Empresa</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#Entrevista -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#Entrevista">
        <rdfs:comment xml:lang="pt">
            Encontro formal entre candidato e empresa no âmbito de uma candidatura.
        </rdfs:comment>
        <rdfs:label xml:lang="pt">Entrevista</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#EntrevistaPresencial -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#EntrevistaPresencial">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/isph/recrutamento#Entrevista"/>
        <rdfs:label xml:lang="pt">Entrevista Presencial</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#EntrevistaRemota -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#EntrevistaRemota">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/isph/recrutamento#Entrevista"/>
        <rdfs:label xml:lang="pt">Entrevista Remota</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#ExperienciaProfissional -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#ExperienciaProfissional">
        <rdfs:comment xml:lang="pt">Registo reificado de experiencia profissional de um candidato ou requisito m?nimo de uma vaga.</rdfs:comment>
        <rdfs:label xml:lang="pt">Experiencia Profissional</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#Formacao -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#Formacao">
        <rdfs:comment xml:lang="pt">
            Habilitação académica ou profissional obtida por um candidato.
        </rdfs:comment>
        <rdfs:label xml:lang="pt">Formação</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#FormacaoAcademica -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#FormacaoAcademica">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/isph/recrutamento#Formacao"/>
        <rdfs:comment xml:lang="pt">Formação obtida em instituição de ensino (Licenciatura, Mestrado, Doutoramento).</rdfs:comment>
        <rdfs:label xml:lang="pt">Formação Académica</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#FormacaoProfissional -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#FormacaoProfissional">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/isph/recrutamento#Formacao"/>
        <rdfs:comment xml:lang="pt">Formação prática ou certificação profissional obtida fora do ensino formal.</rdfs:comment>
        <rdfs:label xml:lang="pt">Formação Profissional</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#Recrutador -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#Recrutador">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/isph/recrutamento#trabalhaEm"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/isph/recrutamento#Empresa"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="pt">
            Profissional responsável pela gestão do processo de recrutamento numa empresa.
        </rdfs:comment>
        <rdfs:label xml:lang="pt">Recrutador</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/isph/recrutamento#Vaga -->

    <owl:Class rdf:about="http://www.semanticweb.org/isph/recrutamento#Vaga">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/isph/recrutamento#isPublicadaPor"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/isph/recrutamento#Empresa"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="pt">
            Posto de trabalho disponível numa empresa, com requisitos de competências
            e formação definidos.
        </rdfs:comment>
        <rdfs:label xml:lang="pt">Vaga</rdfs:label>
    </owl:Class>
    


    <!-- http://xmlns.com/foaf/0.1/Person -->

    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Person"/>
    


